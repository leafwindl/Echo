<view class="character-container {{chatExpanded ? 'chat-expanded' : ''}}">
  <block wx:if="{{chatExpanded}}">
    <view
      class="sit-crop"
      style="width: {{sitCrop.cropWidth}}; height: {{sitCrop.cropHeight}}; margin-left: {{sitCrop.cropOffsetX}}; margin-bottom: {{sitCrop.cropOffsetY}};"
    >
      <image
        class="character-image sit-image"
        src="{{activeAnimationSrc}}"
        mode="widthFix"
        style="width: {{sitCrop.imageWidth}}; left: {{sitCrop.imageLeft}}; top: {{sitCrop.imageTop}};"
      />
    </view>
  </block>
  <block wx:else>
    <view class="name-tag">Echo</view>
    <canvas
      id="idleSpineCanvas"
      type="2d"
      class="spine-canvas idle-spine-canvas"
    />
  </block>
</view>
