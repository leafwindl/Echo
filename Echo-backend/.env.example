# OpenAI 配置
PENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=

# 微信小程序前端
WECHAT_APPID=
WECHAT_SECRET=

# 腾讯云 ASR
TENCENT_SECRET_ID=AKIDxxxxxxxx
TENCENT_SECRET_KEY=xxxxxxxx
TENCENT_APP_ID=130xxxxxxx

# MiniMax TTS
MINIMAX_API_KEY=xxxxxxxx
MINIMAX_GROUP_ID=xxxxxx
MINIMAX_TTS_VOICE_ID=xxxxxx      # 可选，默认可用音色ID；也可以留空，后续克隆用.

# 语音文件清理
VOICE_GENERATED_RETENTION_SECONDS=86400
VOICE_UPLOAD_RETENTION_SECONDS=300
VOICE_CLEANUP_INTERVAL_SECONDS=3600
VOICE_CLEANUP_BATCH_SIZE=500

# embedding 配置
EMBEDDING_API_KEY=你的_embedding_api_key
EMBEDDING_BASE_URL=https://你的服务地址/v1
EMBEDDING_MODEL=你的_embedding模型名
